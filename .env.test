# テスト環境用環境変数

# データベース設定
DATABASE_URL=mysql://test-user:test-password@localhost:3306/gibtee_test

# LINE Bot設定
LINE_CHANNEL_ACCESS_TOKEN=test-access-token
LINE_CHANNEL_SECRET=test-channel-secret

# AWS設定
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
AWS_S3_BUCKET=test-bucket

# 決済設定
LINE_PAY_CHANNEL_ID=test-line-pay-id
LINE_PAY_CHANNEL_SECRET=test-line-pay-secret
STRIPE_SECRET_KEY=test-stripe-key
STRIPE_PUBLISHABLE_KEY=test-stripe-publishable-key

# Slack通知設定
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/test/test/test
SLACK_CHANNEL=#test-notifications
SLACK_USERNAME=gibtee-test-bot

# テスト用設定
TEST_API_URL=http://localhost:3001
TEST_ADMIN_URL=http://localhost:3000

# テスト用管理者アカウント
TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=test-admin-password
TEST_ADMIN_TOKEN=test-jwt-token